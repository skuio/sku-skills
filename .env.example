# Copy to .env and fill in — used by the curl examples in each skill's INSTRUCTIONS.md.
# Never commit your real .env.

# Your SKU.io account subdomain: https://{tenant}.sku.io
SKU_TENANT=app

# A Personal Access Token minted in Settings → Developer → Personal Access Tokens.
# Grant only the scopes your task needs (e.g. products:read, orders:write).
SKU_PAT=sku_pat_replace_me
